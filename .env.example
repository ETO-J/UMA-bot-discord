# ===== 环境模式 =====
ENVIRONMENT=dev
DRIVER=~httpx+~websockets

# ===== API Keys =====
# DeepSeek API (chat / reasoner)
AICHATKEY1=sk-your-deepseek-key

# Bing Search API (via bocha.cn)
BINGSEARCHKEY1=sk-your-bing-key

# Doubao Vision API (image analysis)
VIRSIONKEY1=your-doubao-vision-key

# SauceNAO (anime image search)
SAUCENAO_API_KEY=your-saucenao-key

# Pixiv Refresh Token
PIXIV_REFRESH_TOKEN=your-pixiv-token

# ===== Discord Bot =====
DISCORD_BOTS='
[
  {
    "token": "your-discord-bot-token",
    "intent": {
      "guild_messages": true,
      "direct_messages": true,
      "message_content": true
    },
    "application_commands": {"*": ["*"]}
  }
]
'
DISCORDKEY1=your-discord-bot-token

# ===== Admin =====
ADMIN1=your-discord-user-id
SUPERUSER=your-discord-user-id

# ===== Command Prefix =====
COMMAND_START=["!", ""]

# ===== ComfyUI =====
COMFYUI_URL=http://127.0.0.1:8000
COMFYUI_OUTPUT_DIR=C:\path\to\ComfyUI\output
LORA_BASE_PATH=C:\path\to\ComfyUI\models\loras
IMAGE_SAVE_PATH=C:\path\to\saved\images

# ===== Optional: Ollama (local LLM) =====
# OLLAMA_HOST=http://127.0.0.1:11434/v1
# OLLAMA_MODEL=glm-4.7-flash:latest
